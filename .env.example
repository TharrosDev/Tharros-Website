# Tharros Website — environment scaffold.
# Copy to .env.local for dev. Vercel reads these from Project Settings → Environment Variables.

# ---- Public site URL (used by the resume-link email) ----
NEXT_PUBLIC_SITE_URL=https://tharros.ca

# ---- Supabase (project xbqlfjhriqycqhuiueug, TharrosDev's ORG) ----
# Browser-readable
NEXT_PUBLIC_SUPABASE_URL=https://xbqlfjhriqycqhuiueug.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC_
SUPABASE_URL=https://xbqlfjhriqycqhuiueug.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ---- Upstash Redis (free tier, used for /api/brief rate limit) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Existing integrations ----
# Zapier webhook (downstream forward; optional — local DB is source of truth)
THARROS_WEBHOOK_URL=

# /admin/* HTTP Basic auth password (username is hardcoded as `magnus` in middleware.ts)
ADMIN_PASSWORD=
